# App
APP_ENV=development
APP_NAME=supply-chain-guard
SECRET_KEY=your-secret-key-change-in-production

# Database — SQLite for local dev
DATABASE_URL=sqlite+aiosqlite:///./data/supply_chain_guard.db

# ─────────────────────────────────────────
# LLM PROVIDER — uncomment one block only
# ─────────────────────────────────────────

# Option 1: Anthropic (requires $5 min credit)
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Option 2: Groq (free tier available)
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.3-70b-versatile
# GROQ_API_KEY=your-groq-key-here

# Option 3: OpenAI
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-your-key-here

# Option 4: Ollama (fully local, free)
# LLM_PROVIDER=ollama
# LLM_MODEL=ollama/mistral

# ─────────────────────────────────────────
# LangSmith tracing — optional
# ─────────────────────────────────────────
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=ls__your-key-here
# LANGSMITH_PROJECT=supply-chain-guard
# OLLAMA_BASE_URL=http://localhost:11434

# ─────────────────────────────────────────
# LangSmith — optional agent tracing
# ─────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your-langsmith-key-here
LANGCHAIN_PROJECT=supply-chain-guard